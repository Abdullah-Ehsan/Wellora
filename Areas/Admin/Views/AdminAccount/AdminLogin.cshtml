@model Wellora.Areas.Admin.ViewModels.AdminLoginViewModel

@{
    ViewData["Title"] = "Admin Login";
}

<!-- Bootstrap CSS -->
<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link href="~/css/account/user_login.css" rel="stylesheet" />

<div class="main-screen">
    <div class="login-box shadow">

        <div class="text-center">
            <h2 class="title-text">Admin Login</h2>
            <div class="teal-line"></div>
        </div>

        <form asp-action="AdminLogin" asp-controller="AdminAccount" asp-area="Admin" method="post" class="mt-4">
            <div class="mb-3">
                <label asp-for="LoginIdentifier" class="label-style">Username or Email</label>
                <input asp-for="LoginIdentifier" class="form-control input-field" placeholder="Username or Email" />
                <span asp-validation-for="LoginIdentifier" class="text-danger"></span>
            </div>

            <div class="mb-3 position-relative">
                <label asp-for="Password" class="label-style"></label>
                <input asp-for="Password"
                       class="form-control input-field"
                       id="LoginPassword"
                       type="password"
                       placeholder="Password" />

                <!-- Eye icon toggle -->
                <span class="password-toggle"
                      onclick="togglePassword('LoginPassword','toggleLoginPasswordIcon')">
                    <!-- Start with closed eye (fa-eye-slash) since password is hidden initially -->
                    <i id="toggleLoginPasswordIcon" class="fa fa-eye-slash text-success"></i>
                </span>

                <span asp-validation-for="Password" class="text-danger"></span>
            </div>



            <div class="d-flex justify-content-between mb-4">
                <p>Contact Head Admin for help</p>
            </div>

            <button type="submit" class="btn login-btn w-100">Login</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<script src="~/js/input_validation.js"></script>